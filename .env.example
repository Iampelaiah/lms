# =========================================================================
#                    DR MAX LMS - ENVIRONMENT VARIABLES TEMPLATE
# =========================================================================
# Copy this file to '.env.local' and fill in your local secrets.
# When deploying to Vercel, make sure to add these to your Vercel Project Settings.

# -------------------------------------------------------------------------
# 1. AGORA CORE VOICE & VIDEO BROADCASTING (WebRTC & RTM Signaling)
# -------------------------------------------------------------------------
# Your Agora App ID and Certificate, acquired from the Agora Console (https://console.agora.io).
# AGORA_APP_ID is also mirrored to NEXT_PUBLIC_AGORA_APP_ID for absolute flexibility.
AGORA_APP_ID="your_agora_app_id_here"
NEXT_PUBLIC_AGORA_APP_ID="your_agora_app_id_here"
AGORA_APP_CERTIFICATE="your_agora_app_certificate_here"

# -------------------------------------------------------------------------
# 2. SUPABASE INFRASTRUCTURE (Auth, Database, Storage, and Realtime)
# -------------------------------------------------------------------------
# Acquired from your Supabase Project Settings API Tab (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL="https://your_supabase_project_ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_public_api_key_here"

# -------------------------------------------------------------------------
# 3. AGORA COLLABORATIVE INTERACTIVE WHITEBOARD
# -------------------------------------------------------------------------
# App ID and SDK/Room Tokens from Agora Flat / Netless Whiteboard Console
NEXT_PUBLIC_AGORA_WHITEBOARD_APP_ID="your_whiteboard_app_id_here"
NEXT_PUBLIC_AGORA_WHITEBOARD_SDK_TOKEN="your_whiteboard_sdk_token_here"

# -------------------------------------------------------------------------
# 4. AGORA CHAT (Persistent Messaging and Classroom History)
# -------------------------------------------------------------------------
# The AppKey from your Agora Chat console panel
NEXT_PUBLIC_AGORA_CHAT_APP_KEY="your_agora_chat_app_key_here"

# -------------------------------------------------------------------------
# 5. CONVERSATIONAL AI & VOICE TUTOR AGENTS (Backend Integration)
# -------------------------------------------------------------------------
# OpenAI API Key used by the secure server-side route `/api/agora/convo-ai` to power LLM, TTS, and STT features
OPENAI_API_KEY="your_openai_api_key_here"

# -------------------------------------------------------------------------
# 6. GOOGLE GEMINI AI SERVICES
# -------------------------------------------------------------------------
# Gemini API Key for general LLM study assistants and dashboard modules
GEMINI_API_KEY="your_gemini_api_key_here"
